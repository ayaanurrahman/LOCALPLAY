# ── server ──────────────────────────────
PORT=3000
NODE_ENV=development

# ── database ─────────────────────────────
MONGO_URI=

# ── auth ─────────────────────────────────
JWT_SECRET=

# ── client ───────────────────────────────
CLIENT_URL=http://localhost:5173

# ── email (SMTP) ──────────────────────────
# For development: use Mailtrap (https://mailtrap.io) — free sandbox
# For production:  swap for Resend / SendGrid / SES credentials
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@localplay.app
